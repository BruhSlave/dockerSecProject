FROM golang:1.24-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o dockerSecApp ./cmd/api/



FROM alpine:3.21

WORKDIR /app

COPY --from=builder /app/dockerSecApp .

RUN adduser -D dockeruser
USER dockeruser

EXPOSE 8080

CMD ["./app"]